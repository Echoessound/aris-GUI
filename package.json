{
  "name": "aris-paper-studio",
  "version": "0.1.0",
  "private": true,
  "description": "ARIS 论文生成本地工作台",
  "main": "dist/main/index.cjs",
  "scripts": {
    "install:windows": "powershell -ExecutionPolicy Bypass -File scripts/install.ps1",
    "install:aris-skills": "powershell -ExecutionPolicy Bypass -File scripts/install-aris-skills.ps1",
    "dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "check:i18n": "node scripts/check-ui-copy.mjs",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --format=cjs --outfile=dist/main/index.cjs --external:electron --external:better-sqlite3 --external:simple-git && esbuild src/preload/index.ts --bundle --platform=node --format=cjs --outfile=dist/preload/index.cjs --external:electron",
    "build": "pnpm typecheck && vite build && pnpm build:main",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "start": "electron .",
    "dist": "pnpm build && cross-env ELECTRON_BUILDER_CACHE=.cache/electron-builder CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable --config.win.signAndEditExecutable=false"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "antd": "^5.24.2",
    "better-sqlite3": "^11.8.1",
    "execa": "^9.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "react-router-dom": "^7.3.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.0",
    "simple-git": "^3.27.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.21.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "eslint": "^9.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.2.1",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "cn.aris.paperstudio",
    "productName": "ARIS Paper Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
